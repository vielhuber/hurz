# ------------------------------------------------------------------
# Pocket Option (legacy binary-options broker — used only when
# data/settings.json -> trade_platform == "pocketoption")
# ------------------------------------------------------------------
IP_ADDRESS="xxx.xxx.xxx.xxx"
USER_ID="xxxxxxxx"
LIVE_SUFFIX_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
LIVE_SESSION_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
DEMO_SESSION_ID="xxxxxxxxxxxxxxxxxxxxxxxxxx"

# ------------------------------------------------------------------
# Kraken Spot Exchange (trade_platform == "kraken")
# Generate at: https://www.kraken.com/u/security/api
# Permissions: Query Funds + Query Open/Closed Orders + Create &
# Modify Orders. NO withdraw permission — keep that disabled.
# Leave both empty for paper / data-only mode (public endpoints
# still work).
# ------------------------------------------------------------------
KRAKEN_API_KEY=""
KRAKEN_API_SECRET=""

# ------------------------------------------------------------------
# Capital.com (trade_platform == "capital_com")
# Generate API key in the web UI: Settings → API integrations
# (2FA must be enabled first). The identifier is your account email.
# CAPITAL_COM_DEMO defaults to 1 — set to 0 ONLY when you intend to
# trade real money.
# ------------------------------------------------------------------
CAPITAL_COM_API_KEY=""
CAPITAL_COM_IDENTIFIER=""
CAPITAL_COM_PASSWORD=""
CAPITAL_COM_DEMO="1"

# ------------------------------------------------------------------
# Global paper-trade safety. Defaults to "1" — every platform refuses
# to place real orders until this is explicitly flipped to "0". Read-
# only methods (history, balance, positions list) are unaffected.
# Always pair PAPER_TRADE_ONLY=0 with a sandbox/demo endpoint until
# the strategy is fully validated on live data.
# ------------------------------------------------------------------
PAPER_TRADE_ONLY="1"

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------
DB_HOST="localhost"
DB_PORT=3306
DB_NAME="hurz"
DB_USERNAME="root"
DB_PASSWORD="root"

PROXY="USERNAME:PASSWORD@IP_ADDRESS:PORT"
